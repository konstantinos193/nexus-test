# Frontend Staging Environment Variables Template
# Copy this to .env.staging and fill in actual values

# Web3 Networks
NEXT_PUBLIC_WEB3_NETWORK=devnet

# API Configuration
NEXT_PUBLIC_API_URL=https://staging.yourdomain.com/api
NEXT_PUBLIC_APP_URL=https://staging.yourdomain.com

# Solana Configuration
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PHANTOM_WALLET_ENABLED=true

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# Rate Limiting (more relaxed for testing)
NEXT_PUBLIC_RATE_LIMIT_MAX=1000
NEXT_PUBLIC_RATE_LIMIT_WINDOW=900000

# Cache Configuration
NEXT_PUBLIC_CACHE_TTL=1800

# Security
NEXT_PUBLIC_SECURITY_HEADERS=true
