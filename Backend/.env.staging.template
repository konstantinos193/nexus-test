# Backend Staging Environment Variables Template
# Copy this to .env.staging and fill in actual values

# Database Configuration
DATABASE_URL=postgresql://martech_user:${DB_PASSWORD}@postgres:5432/martech_staging
DB_PASSWORD=your_staging_database_password

# Redis Configuration
REDIS_URL=redis://redis:6379

# Solana Configuration
WEB3_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Security
JWT_SECRET=your_staging_jwt_secret_minimum_32_characters
ENCRYPTION_KEY=your_staging_encryption_key_minimum_32_characters

# Node Configuration
NODE_ENV=staging
PORT=8000

# Solana Performance
WEB3_REQUEST_TIMEOUT=60000
WEB3_RETRY_ATTEMPTS=5
WEB3_RETRY_DELAY=2000
SOLANA_COMMITMENT=confirmed

# IPFS Configuration
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
IPFS_API_URL=https://api.ipfs.io/api/v0/

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Session Management
SESSION_SECRET=your_staging_session_secret_minimum_32_characters
SESSION_TTL=7200

# Rate Limiting (relaxed for testing)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Cache Configuration
CACHE_TTL=1800
CACHE_MAX_SIZE=50

# Health Checks
HEALTH_CHECK_INTERVAL=15000
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_RETRIES=2

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=false
