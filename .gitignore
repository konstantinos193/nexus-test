# Root .gitignore – monorepo (Frontend, Backend, Milestone2-Frontend, programs, admin)
# See https://help.github.com/articles/ignoring-files/

# Dependencies – ignore node_modules everywhere
node_modules/

# Local env files – never commit secrets
.env
.env.local
.env.*.local
!.env.example
!env.example
!env.localnet.example

# Build / output
.next/
out/
build/
dist/
*.tsbuildinfo

# Testing / coverage
coverage/
.nyc_output/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs / debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel / deploy
.vercel

# Temporary / one-off (e.g. commit message file used for push)
COMMIT_MSG.txt

# Optional: uncomment if you want to ignore pnp
# .pnp
# .pnp.js
