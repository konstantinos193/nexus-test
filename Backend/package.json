{
  "name": "nexus-backend",
  "version": "1.0.0",
  "description": "NeXus NFT Launchpad Backend API",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:migrate": "docker-compose -f docker-compose.dev.yml run --rm backend sh -c \"npm install && npx prisma migrate deploy\"",
    "docker:migrate-resolve": "docker-compose -f docker-compose.dev.yml run --rm backend sh -c \"npm install && npx prisma migrate resolve --applied 20250101000000_init\"",
    "docker:migrate-create": "docker-compose -f docker-compose.dev.yml run --rm backend npx prisma migrate dev --name add_collection_slug --create-only",
    "docker:prod": "docker-compose up -d",
    "docker:prod:build": "docker-compose up -d --build",
    "docker:prod:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f backend"
  },
  "keywords": ["nestjs", "nft", "launchpad", "api"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/swagger": "^11.2.5",
    "@prisma/client": "^6.1.0",
    "@solana/web3.js": "^1.95.8",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/node": "^25.0.10",
    "dotenv": "^16.4.5",
    "nodemon": "^3.1.11",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
