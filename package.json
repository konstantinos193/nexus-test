{
  "name": "nexus-frontend",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "homepage": "https://nexus-web3.com",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "reinstall": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); require('fs').rmSync('node_modules',{recursive:true,force:true})\" && yarn install",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build --webpack",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "perf:test": "npm run build && npm run start"
  },
  "dependencies": {
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@metaplex-foundation/umi": "^1.4.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.4.1",
    "@phantom/react-sdk": "^1.0.2",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-fake": "^0.1.5",
    "@solana/wallet-adapter-ledger": "^0.9.29",
    "@solana/wallet-adapter-phantom": "^0.9.28",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-solflare": "^0.6.32",
    "@solana/wallet-adapter-trust": "^0.1.17",
    "@solana/web3.js": "^1.98.4",
    "@solflare-wallet/metamask-wallet-standard": "^1.0.11",
    "@tanstack/react-query": "^5.90.20",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "install": "^0.13.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "npm": "^11.8.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@noble/hashes": "^1.3.3"
  }
}
