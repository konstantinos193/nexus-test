# Frontend Production Environment Variables Template
# Copy this to .env.production and fill in actual values

# Web3 Networks
NEXT_PUBLIC_WEB3_NETWORK=mainnet

# API Configuration
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Solana Configuration
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.rpc.helius.xyz/?api-key=your_helius_api_key
NEXT_PUBLIC_PHANTOM_WALLET_ENABLED=true

# Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# Rate Limiting
NEXT_PUBLIC_RATE_LIMIT_MAX=100
NEXT_PUBLIC_RATE_LIMIT_WINDOW=900000

# Cache Configuration
NEXT_PUBLIC_CACHE_TTL=3600

# Security
NEXT_PUBLIC_SECURITY_HEADERS=true
