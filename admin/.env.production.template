# Admin Production Environment Variables Template
# Copy this to .env.production and fill in actual values

# API Configuration
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_APP_URL=https://yourdomain.com/admin

# Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# Rate Limiting
NEXT_PUBLIC_RATE_LIMIT_MAX=50
NEXT_PUBLIC_RATE_LIMIT_WINDOW=900000

# Cache Configuration
NEXT_PUBLIC_CACHE_TTL=1800

# Security
NEXT_PUBLIC_SECURITY_HEADERS=true
NEXT_PUBLIC_CSP_ENABLED=true
NEXT_PUBLIC_ADMIN_ONLY_MODE=true

# Session Configuration
NEXT_PUBLIC_SESSION_TIMEOUT=3600000

# Monitoring
NEXT_PUBLIC_HEALTH_CHECK_ENABLED=true
NEXT_PUBLIC_METRICS_ENABLED=true
