# Database
DATABASE_URL="postgresql://postgres:nexus123@localhost:5432/nexus_db?schema=public"
# For Supabase: DATABASE_URL="postgresql://user:password@db.xxxxx.supabase.co:5432/postgres"

# Server
PORT=8000
FRONTEND_URL=http://localhost:3000

# API Key (for backend authentication)
# This key is validated by the backend when requests come from Next.js API routes
# Generate with: openssl rand -hex 32
API_KEY=543ef675f15bf0d12b03e88a0f7026b3806c76cb447f2b3787e0039259785cad

# Solana Configuration (Devnet by default; use localnet for local validator)
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# For localnet: SOLANA_NETWORK=localnet and SOLANA_RPC_URL=http://127.0.0.1:8899
# For custom RPC: SOLANA_RPC_URL=https://your-custom-rpc-url.com
# Commitment level: processed, confirmed, or finalized
SOLANA_COMMITMENT=confirmed

# Smart Contract Program IDs (from anchor program deploy / programs/Anchor.toml)
# nexus_launchpad (minting), nexus_payment, nexus_collection
# For devnet/mainnet use IDs from: anchor deploy --provider.cluster devnet
MINTING_PROGRAM_ID=w6ELig1b3oETMQmiJkvPtyu99fnPwAGMJYSnaTXphma
PAYMENT_PROGRAM_ID=8VLcrDKmzMXM1hDBzEU9ifRvaYSbuC4kfAF2tNa1qU9Z
COLLECTION_PROGRAM_ID=BUkDSb56YuM9Q1BsiokLKPfaUYP84AzE7xLfVXtqQzTi

# IPFS Configuration
# Mode: 'http' for HTTP client (connects to existing IPFS node), 'local' for local node (not yet implemented)
IPFS_MODE=http

# IPFS HTTP Client Configuration (when IPFS_MODE=http)
# API URL of your IPFS node (default: http://localhost:5001)
IPFS_API_URL=http://localhost:5001
# Gateway URL for retrieving files (default: http://localhost:8080)
IPFS_GATEWAY_URL=http://localhost:8080
# Optional: API key if your IPFS node requires authentication (e.g., for Pinata)
IPFS_API_KEY=

# IPFS Public Gateway URL (for sharing IPFS hashes publicly)
# This is the URL that will be used in metadata URIs
IPFS_PUBLIC_GATEWAY_URL=https://ipfs.io/ipfs/

# IPFS Pinning Configuration
# Auto-pin uploaded files (default: true)
IPFS_AUTO_PIN=true
# Pin timeout in milliseconds (default: 30000)
IPFS_PIN_TIMEOUT=30000

# IPFS Gateway CORS (default: true)
IPFS_GATEWAY_CORS=true

# IPFS Local Node Configuration (when IPFS_MODE=local, not yet implemented)
# IPFS_REPO_PATH=./.ipfs

# JWT (for auth - add when ready)
# JWT_SECRET=your_jwt_secret_key
