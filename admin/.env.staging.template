# Admin Staging Environment Variables Template
# Copy this to .env.staging and fill in actual values

# API Configuration
NEXT_PUBLIC_API_URL=https://staging.yourdomain.com/api
NEXT_PUBLIC_APP_URL=https://staging.yourdomain.com/admin

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# Rate Limiting (relaxed for testing)
NEXT_PUBLIC_RATE_LIMIT_MAX=500
NEXT_PUBLIC_RATE_LIMIT_WINDOW=900000

# Cache Configuration
NEXT_PUBLIC_CACHE_TTL=1800

# Security
NEXT_PUBLIC_SECURITY_HEADERS=true

# Session Configuration
NEXT_PUBLIC_SESSION_TIMEOUT=3600000

# Monitoring
NEXT_PUBLIC_HEALTH_CHECK_ENABLED=true
NEXT_PUBLIC_METRICS_ENABLED=false
