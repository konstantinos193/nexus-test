{
  "name": "nexus-frontend",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build --webpack",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 1000 --ignore-pattern \".next/**\" --ignore-pattern \"node_modules/**\"",
    "perf:test": "npm run build && npm run start",
    "spaghetti:check": "node scripts/spaghetti-detector.cjs",
    "spaghetti:check:strict": "node scripts/spaghetti-detector.cjs --max-lines=300 --max-props=6",
    "prepare": "husky install",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:start:staging": "pm2 start ecosystem.config.js --env staging",
    "pm2:restart": "pm2 restart nexus-frontend",
    "pm2:restart:prod": "pm2 restart ecosystem.config.js --env production",
    "pm2:restart:staging": "pm2 restart ecosystem.config.js --env staging",
    "pm2:stop": "pm2 stop nexus-frontend",
    "pm2:delete": "pm2 delete nexus-frontend",
    "pm2:logs": "pm2 logs nexus-frontend",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.101.0",
    "@web3modal/wagmi": "^5.1.11",
    "clsx": "^2.1.1",
    "ethers": "^6.16.0",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "viem": "^2.52.2",
    "wagmi": "^3.6.16"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pino-pretty": "^13.1.3",
    "pm2": "^7.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "node scripts/spaghetti-detector.cjs"
    ]
  }
}
