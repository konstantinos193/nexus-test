# Copy to .env.local when using localnet: copy env.localnet.example .env.local (or merge into existing .env.local)
# Frontend localnet – wallet and RPC point at solana-test-validator

NEXT_PUBLIC_SOLANA_NETWORK=localnet
NEXT_PUBLIC_SOLANA_RPC_URL=http://127.0.0.1:8899

# Program IDs (from programs/Anchor.toml [programs.localnet])
NEXT_PUBLIC_MINTING_PROGRAM_ID=w6ELig1b3oETMQmiJkvPtyu99fnPwAGMJYSnaTXphma
NEXT_PUBLIC_PAYMENT_PROGRAM_ID=8VLcrDKmzMXM1hDBzEU9ifRvaYSbuC4kfAF2tNa1qU9Z
# Whitelist/allowlist is handled by nexus_launchpad (same as minting)
NEXT_PUBLIC_WHITELIST_PROGRAM_ID=w6ELig1b3oETMQmiJkvPtyu99fnPwAGMJYSnaTXphma

# Optional: backend URL for API routes (defaults to http://localhost:8000)
# BACKEND_URL=http://localhost:8000
# BACKEND_API_KEY=your_api_key_from_backend_env
