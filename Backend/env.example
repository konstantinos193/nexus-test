# Database
DATABASE_URL="postgresql://postgres:nexus123@localhost:5432/nexus_db?schema=public"
# For Supabase: DATABASE_URL="postgresql://user:password@db.xxxxx.supabase.co:5432/postgres"

# Server
PORT=8000
FRONTEND_URL=http://localhost:3000

# API Key (for backend authentication)
# This key is validated by the backend when requests come from Next.js API routes
# Generate with: openssl rand -hex 32
API_KEY=543ef675f15bf0d12b03e88a0f7026b3806c76cb447f2b3787e0039259785cad

# Solana Configuration (Devnet)
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# For custom RPC: SOLANA_RPC_URL=https://your-custom-rpc-url.com
# Commitment level: processed, confirmed, or finalized
SOLANA_COMMITMENT=confirmed

# Smart Contract Program IDs (update after deployment)
# Get these from: anchor deploy --provider.cluster devnet
MINTING_PROGRAM_ID=your_minting_program_id_here
PAYMENT_PROGRAM_ID=your_payment_program_id_here
COLLECTION_PROGRAM_ID=your_collection_program_id_here

# IPFS (add when ready)
# IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
# PINATA_API_KEY=your_pinata_api_key
# PINATA_SECRET_KEY=your_pinata_secret_key

# JWT (for auth - add when ready)
# JWT_SECRET=your_jwt_secret_key
