# Backend Production Environment Variables Template
# Copy this to .env.production and fill in actual values

# Database Configuration
DATABASE_URL=postgresql://martech_user:${DB_PASSWORD}@postgres:5432/martech_production
DB_PASSWORD=your_secure_database_password_here

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=your_secure_redis_password_here

# Solana Configuration
WEB3_NETWORK=mainnet
SOLANA_RPC_URL=https://mainnet.rpc.helius.xyz/?api-key=your_helius_api_key

# Security
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
ENCRYPTION_KEY=your_encryption_key_minimum_32_characters_long

# Node Configuration
NODE_ENV=production
PORT=8000

# Solana Performance
WEB3_REQUEST_TIMEOUT=30000
WEB3_RETRY_ATTEMPTS=3
WEB3_RETRY_DELAY=1000
SOLANA_COMMITMENT=confirmed

# IPFS Configuration
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
IPFS_API_URL=https://api.ipfs.io/api/v0/

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Session Management
SESSION_SECRET=your_session_secret_minimum_32_characters
SESSION_TTL=86400

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# Health Checks
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=10000
HEALTH_CHECK_RETRIES=3

# Monitoring
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9464

# Email Configuration (for notifications)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_email@yourdomain.com
SMTP_PASS=your_email_password
