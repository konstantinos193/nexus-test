# Solana Launchpad — production wallet + RPC
# Copy to .env.local and fill in values.

# Network: mainnet-beta | devnet | testnet | localnet
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# RPC: use Helius / QuickNode / Triton (never public mainnet in production)
NEXT_PUBLIC_RPC_URL=https://your-premium-rpc-url
# Or legacy key (same effect):
# NEXT_PUBLIC_SOLANA_RPC_URL=https://your-premium-rpc-url

# Program IDs (from anchor program deploy / programs/Anchor.toml)
# For localnet use these; for devnet/mainnet use IDs from anchor deploy --provider.cluster devnet
NEXT_PUBLIC_MINTING_PROGRAM_ID=w6ELig1b3oETMQmiJkvPtyu99fnPwAGMJYSnaTXphma
NEXT_PUBLIC_PAYMENT_PROGRAM_ID=8VLcrDKmzMXM1hDBzEU9ifRvaYSbuC4kfAF2tNa1qU9Z
NEXT_PUBLIC_WHITELIST_PROGRAM_ID=w6ELig1b3oETMQmiJkvPtyu99fnPwAGMJYSnaTXphma

# WalletConnect: required for WalletConnect adapter (mobile QR / Trust etc.)
# Get project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_ID
